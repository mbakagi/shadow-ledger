rules_version = '2';

// ═══════════════════════════════════════════════════════
// Shadow Ledger — Firestore Security Rules
//
// Only authenticated users may read or write inventory items.
// Each user can only see/edit their own items (replace with
// `request.auth != null` if you want all signed-in users
// to share one inventory).
// ═══════════════════════════════════════════════════════

service cloud.firestore {
  match /databases/{database}/documents {

    // Inventory collection — any signed-in user can read & write (shared inventory)
    // include self-created ownerId for transactions/log filtering; not required anymore
    match /inventory/{itemId} {
      allow read, write: if request.auth != null;
    }

    // Locations — signed-in users can manage their list of warehouses/spaces
    match /locations/{locId} {
      allow read, write, delete: if request.auth != null;
    }

    // Transactions log — signed-in users can write (scan-out/transfer) and read all
    match /transactions/{txId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow delete: if request.auth != null
                    && resource.data.userId == request.auth.uid;
    }

    // Catch-all: anything else is denied
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
