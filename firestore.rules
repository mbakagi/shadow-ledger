rules_version = '2';

// ═══════════════════════════════════════════════════════
// St3s — Firestore Security Rules
//
// Auth-gated access for all collections. No timestamp
// expiration — secured via request.auth checks instead.
// Validates field types on writes to prevent schema abuse.
// ═══════════════════════════════════════════════════════

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Inventory ──
    match /inventory/{itemId} {
      allow read: if request.auth != null;

      allow create: if request.auth != null
        && request.resource.data.sku is string
        && request.resource.data.sku.matches('^[A-Za-z0-9\\-_.]{1,60}$')
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0
        && request.resource.data.name.size() <= 200
        && request.resource.data.totalStock is int
        && request.resource.data.totalStock >= 0
        && request.resource.data.carrierTrigger is int
        && request.resource.data.carrierTrigger >= 0
        && request.resource.data.maxCapacity is int
        && request.resource.data.maxCapacity >= 0
        && request.resource.data.purchasingTrigger is int
        && request.resource.data.purchasingTrigger >= 0;

      allow update: if request.auth != null
        && request.resource.data.sku is string
        && request.resource.data.totalStock is int
        && request.resource.data.totalStock >= 0
        && request.resource.data.carrierTrigger is int
        && request.resource.data.carrierTrigger >= 0
        && request.resource.data.maxCapacity is int
        && request.resource.data.maxCapacity >= 0
        && request.resource.data.purchasingTrigger is int
        && request.resource.data.purchasingTrigger >= 0;

      allow delete: if request.auth != null;
    }

    // ── Locations ──
    match /locations/{locId} {
      allow read: if request.auth != null;

      allow create: if request.auth != null
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0
        && request.resource.data.name.size() <= 100
        && request.resource.data.order is int;

      allow update: if request.auth != null
        && request.resource.data.name is string
        && request.resource.data.name.size() <= 100;

      allow delete: if request.auth != null;
    }

    // ── Transactions (immutable audit ledger) ──
    match /transactions/{txId} {
      allow read: if request.auth != null;

      allow create: if request.auth != null
        && request.resource.data.itemId is string
        && request.resource.data.itemId.size() > 0
        && request.resource.data.sku is string
        && request.resource.data.sku.size() > 0
        && request.resource.data.qtyOut is int
        && request.resource.data.qtyOut >= 0
        && request.resource.data.type is string
        && request.resource.data.type in ['scan-out', 'transfer', 'adjust'];

      // Immutable: no updates or deletes allowed after creation
      allow update: if false;
      allow delete: if false;
    }

    // ── Catch-all deny ──
    match /{document=**} {
      allow read, write: if false;
    }
  }
}